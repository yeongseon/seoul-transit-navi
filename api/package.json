{
  "name": "api",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply seoul-transit --remote",
    "db:seed": "wrangler d1 execute seoul-transit --remote --file=../data/seed.sql",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.39.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4",
    "wrangler": "^3.99.0"
  }
}
